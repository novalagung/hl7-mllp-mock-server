    { "match": "ADT^A31", "response": "AA", "ack_text": "Person information updated" },
    { "match": "ADT^A37", "response": "AA", "ack_text": "Patient unlinked" },
    { "match": "ADT^A40", "response": "AA", "ack_text": "Patient merged" },
    { "match": "ADT^A41", "response": "AA", "ack_text": "Account merged" },
